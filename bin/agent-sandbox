#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MODE_FILE="$ROOT/runtime/state/compose-mode"

usage() {
  cat <<'EOF'
Usage:
  bin/agent-sandbox up [default|simple]
  bin/agent-sandbox down [default|simple]
  bin/agent-sandbox shell [default|simple]
  bin/agent-sandbox logs [default|simple]
  bin/agent-sandbox doctor
EOF
}

mode_path() {
  case "${1:-default}" in
    default|full|'')
      printf '%s\n' "$ROOT/compose.yaml"
      ;;
    simple|lite|minimal)
      printf '%s\n' "$ROOT/compose.simple.yaml"
      ;;
    *)
      printf 'bin/agent-sandbox: unknown mode `%s` (expected `default` or `simple`)\n' "$1" >&2
      exit 1
      ;;
  esac
}

mode_name() {
  case "${1:-default}" in
    default|full|'') printf 'default\n' ;;
    simple|lite|minimal) printf 'simple\n' ;;
    *)
      printf 'bin/agent-sandbox: unknown mode `%s` (expected `default` or `simple`)\n' "$1" >&2
      exit 1
      ;;
  esac
}

resolve_mode() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    mode_name "$explicit"
    return
  fi
  if [[ -f "$MODE_FILE" ]]; then
    local persisted
    persisted="$(tr -d '[:space:]' < "$MODE_FILE")"
    if [[ -n "$persisted" ]]; then
      mode_name "$persisted"
      return
    fi
  fi
  printf 'default\n'
}

compose_cmd() {
  local mode="$1"
  shift
  local compose_file
  compose_file="$(mode_path "$mode")"
  docker compose -f "$compose_file" "$@"
}

SANDBOX_UID=1000

dir_uid() {
  # GNU stat first (Linux), then BSD stat (macOS).
  stat -c %u "$1" 2>/dev/null || stat -f %u "$1" 2>/dev/null
}

# The sandbox container runs as uid 1000 with read_only root. On Linux hosts
# whose user uid is not 1000 (e.g. CI runners, multi-user dev boxes), bind
# mounts inherit the host uid and the entrypoint cannot mkdir into /state etc.,
# so the container exits immediately. Docker Desktop on macOS hides this with
# its own uid translation, so we skip the check there.
check_runtime_perms() {
  if [[ "$(uname -s)" != "Linux" ]]; then
    return 0
  fi
  local dir owner_uid bad=0
  for dir in workspaces state logs tool-bin; do
    local target="${AGENT_SANDBOX_RUNTIME_OVERRIDE:-$ROOT/runtime/$dir}"
    [[ -d "$target" ]] || continue
    owner_uid="$(dir_uid "$target")"
    if [[ -n "$owner_uid" && "$owner_uid" != "$SANDBOX_UID" ]]; then
      bad=1
      printf 'bin/agent-sandbox: %s owned by uid %s (expected %s)\n' \
        "$target" "$owner_uid" "$SANDBOX_UID" >&2
    fi
  done
  if [[ "$bad" == 1 ]]; then
    cat >&2 <<EOF
bin/agent-sandbox: sandbox container runs as uid $SANDBOX_UID; mismatched
  bind-mount ownership will make the entrypoint fail to mkdir into /state and
  the container will exit on start. Fix:
    sudo chown -R $SANDBOX_UID:$SANDBOX_UID "$ROOT/runtime"
EOF
    return 1
  fi
}

doctor() {
  command -v docker >/dev/null
  command -v jq >/dev/null
  test -f "$ROOT/compose.yaml"
  test -f "$ROOT/compose.simple.yaml"
  test -f "$ROOT/config/mcp-gateway/servers.json"
  test -f "$ROOT/mcp-gateway/Dockerfile"
  test -d "$ROOT/runtime/workspaces"
  test -d "$ROOT/runtime/logs"
  test -d "$ROOT/runtime/state"
  test -d "$ROOT/runtime/tool-bin"
  check_runtime_perms
  echo "doctor: ok"
}

service_running() {
  local mode="$1" service="$2"
  local cid status
  cid="$(compose_cmd "$mode" ps -q "$service" 2>/dev/null || true)"
  if [[ -z "$cid" ]]; then
    return 1
  fi
  status="$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || true)"
  [[ "$status" == "running" ]]
}

wait_for_service() {
  local mode="$1" service="$2"
  local attempts=30
  local i
  for ((i = 0; i < attempts; i++)); do
    if service_running "$mode" "$service"; then
      return 0
    fi
    sleep 1
  done
  printf 'bin/agent-sandbox: service `%s` failed to reach running state\n' "$service" >&2
  return 1
}

start_mode() {
  local mode="$1"
  check_runtime_perms
  local prereqs=(proxy)
  if [[ "$mode" == "default" ]]; then
    prereqs+=(mcp-gateway)
  fi
  compose_cmd "$mode" up -d "${prereqs[@]}"
  for svc in "${prereqs[@]}"; do
    wait_for_service "$mode" "$svc"
  done
  compose_cmd "$mode" up -d --no-deps sandbox
  printf '%s\n' "$mode" > "$MODE_FILE"
}

ensure_sandbox_running() {
  local mode="$1"
  if service_running "$mode" sandbox; then
    return
  fi
  start_mode "$mode"
}

case "${1:-}" in
  up)
    mode="$(resolve_mode "${2:-}")"
    start_mode "$mode"
    ;;
  down)
    mode="$(resolve_mode "${2:-}")"
    compose_cmd "$mode" down
    rm -f "$MODE_FILE"
    ;;
  shell)
    mode="$(resolve_mode "${2:-}")"
    ensure_sandbox_running "$mode"
    compose_cmd "$mode" exec sandbox zsh -i
    ;;
  logs)
    mode="$(resolve_mode "${2:-}")"
    compose_cmd "$mode" logs --tail=50
    ;;
  doctor) doctor ;;
  *) usage; exit 1 ;;
esac
