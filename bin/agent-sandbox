#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

load_orchestration_helpers() {
  # shellcheck disable=SC1091
  source "$ROOT/orchestration/lib/common.sh"
  # shellcheck disable=SC1091
  source "$ROOT/orchestration/lib/profile.sh"
}

compose_args() {
  local compose_root
  compose_root="${COMPOSE_ROOT:-deploy/compose}"

  COMPOSE_ARGS=(-p "${COMPOSE_PROJECT_NAME:-agent_sandbox}" -f "$ROOT/$compose_root/compose.yaml")
}

usage() {
  cat <<'EOF'
Usage:
  bin/agent-sandbox up [profile]
  bin/agent-sandbox down
  bin/agent-sandbox shell
  bin/agent-sandbox logs
  bin/agent-sandbox doctor
EOF
}

doctor() {
  command -v docker >/dev/null
  command -v jq >/dev/null
  test -f "$ROOT/${COMPOSE_ROOT:-deploy/compose}/compose.yaml"
  test -f "$ROOT/config/mcp-gateway/servers.json"
  test -f "$ROOT/mcp-gateway/Dockerfile"
  test -d "$ROOT/runtime/workspaces"
  test -d "$ROOT/runtime/home"
  test -d "$ROOT/runtime/logs"
  test -d "$ROOT/runtime/state"
  echo "doctor: ok"
}

case "${1:-}" in
  up)
    load_orchestration_helpers
    profile="${2:-}"
    load_profile "$profile"
    compose_env
    compose_args
    docker compose "${COMPOSE_ARGS[@]}" up -d
    ;;
  down)
    load_orchestration_helpers
    load_env_file "$ROOT/config/defaults.env"
    compose_args
    docker compose "${COMPOSE_ARGS[@]}" down
    ;;
  shell)
    load_orchestration_helpers
    load_env_file "$ROOT/config/defaults.env"
    compose_args
    docker compose "${COMPOSE_ARGS[@]}" exec sandbox zsh -i
    ;;
  logs)
    load_orchestration_helpers
    load_env_file "$ROOT/config/defaults.env"
    compose_args
    docker compose "${COMPOSE_ARGS[@]}" logs --tail=50
    ;;
  doctor) doctor ;;
  *) usage; exit 1 ;;
esac
