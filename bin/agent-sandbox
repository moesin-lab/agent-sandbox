#!/usr/bin/env bash
set -euo pipefail

# Resolve the repo root through any symlinks so the script works whether it's
# invoked directly, via a `bin/` entry on PATH, or via a symlink in PATH (e.g.
# ~/.local/bin/agent-sandbox -> /path/to/repo/bin/agent-sandbox).
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  dir="$(cd -P "$(dirname "$SOURCE")" >/dev/null && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$dir/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." >/dev/null && pwd)"
MODE_FILE="$ROOT/runtime/state/compose-mode"
SELF_FILE="$ROOT/runtime/state/compose-self"

usage() {
  cat <<'EOF'
Usage:
  bin/agent-sandbox up [default|simple] [--self]
  bin/agent-sandbox down [default|simple]
  bin/agent-sandbox shell [default|simple]
  bin/agent-sandbox logs [default|simple]
  bin/agent-sandbox doctor
  bin/agent-sandbox <cli> [args...]
      Run a container-side CLI (claude / codex / opencode / ...) at the
      cwd-mapped path inside the sandbox. cwd under the workspace mount
      (AGENT_SANDBOX_WORKSPACE_DIR; default ./runtime/workspaces) maps to
      /workspace/<rel>; cwd under the self mount (AGENT_SANDBOX_SELF_DIR,
      requires --self at up time) maps to /self/<rel>; otherwise falls back
      to /workspace.
EOF
}

mode_path() {
  case "${1:-default}" in
    default|full|'')
      printf '%s\n' "$ROOT/compose.yaml"
      ;;
    simple|lite|minimal)
      printf '%s\n' "$ROOT/compose.simple.yaml"
      ;;
    *)
      printf 'bin/agent-sandbox: unknown mode `%s` (expected `default` or `simple`)\n' "$1" >&2
      exit 1
      ;;
  esac
}

mode_name() {
  case "${1:-default}" in
    default|full|'') printf 'default\n' ;;
    simple|lite|minimal) printf 'simple\n' ;;
    *)
      printf 'bin/agent-sandbox: unknown mode `%s` (expected `default` or `simple`)\n' "$1" >&2
      exit 1
      ;;
  esac
}

resolve_mode() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    mode_name "$explicit"
    return
  fi
  if [[ -f "$MODE_FILE" ]]; then
    local persisted
    persisted="$(tr -d '[:space:]' < "$MODE_FILE")"
    if [[ -n "$persisted" ]]; then
      mode_name "$persisted"
      return
    fi
  fi
  printf 'default\n'
}

compose_cmd() {
  local mode="$1"
  shift
  local compose_file
  compose_file="$(mode_path "$mode")"
  # --project-directory pins relative paths (build context, host volumes) and
  # .env discovery to the repo root, so the script behaves identically no
  # matter which cwd the user invokes it from.
  local args=(--project-directory "$ROOT" -f "$compose_file")
  # Stack the self overlay if a previous `up --self` left the sentinel.
  if [[ -f "$SELF_FILE" ]]; then
    args+=(-f "$ROOT/compose.self.yaml")
  fi
  docker compose "${args[@]}" "$@"
}

SANDBOX_UID=1000

dir_uid() {
  # GNU stat first (Linux), then BSD stat (macOS).
  stat -c %u "$1" 2>/dev/null || stat -f %u "$1" 2>/dev/null
}

# The sandbox container runs as uid 1000 with read_only root. On Linux hosts
# whose user uid is not 1000 (e.g. CI runners, multi-user dev boxes), bind
# mounts inherit the host uid and the entrypoint cannot mkdir into /state etc.,
# so the container exits immediately. Docker Desktop on macOS hides this with
# its own uid translation, so we skip the check there.
check_runtime_perms() {
  if [[ "$(uname -s)" != "Linux" ]]; then
    return 0
  fi
  local dir owner_uid bad=0
  for dir in workspaces state logs tool-bin; do
    local target="${AGENT_SANDBOX_RUNTIME_OVERRIDE:-$ROOT/runtime/$dir}"
    [[ -d "$target" ]] || continue
    owner_uid="$(dir_uid "$target")"
    if [[ -n "$owner_uid" && "$owner_uid" != "$SANDBOX_UID" ]]; then
      bad=1
      printf 'bin/agent-sandbox: %s owned by uid %s (expected %s)\n' \
        "$target" "$owner_uid" "$SANDBOX_UID" >&2
    fi
  done
  if [[ "$bad" == 1 ]]; then
    cat >&2 <<EOF
bin/agent-sandbox: sandbox container runs as uid $SANDBOX_UID; mismatched
  bind-mount ownership will make the entrypoint fail to mkdir into /state and
  the container will exit on start. Fix:
    sudo chown -R $SANDBOX_UID:$SANDBOX_UID "$ROOT/runtime"
EOF
    return 1
  fi
}

doctor() {
  command -v docker >/dev/null
  command -v jq >/dev/null
  test -f "$ROOT/compose.yaml"
  test -f "$ROOT/compose.simple.yaml"
  test -f "$ROOT/config/mcp-gateway/servers.json"
  test -f "$ROOT/mcp-gateway/Dockerfile"
  test -d "$ROOT/runtime/workspaces"
  test -d "$ROOT/runtime/logs"
  test -d "$ROOT/runtime/state"
  test -d "$ROOT/runtime/tool-bin"
  check_runtime_perms
  echo "doctor: ok"
}

service_running() {
  local mode="$1" service="$2"
  local cid status health
  cid="$(compose_cmd "$mode" ps -q "$service" 2>/dev/null || true)"
  if [[ -z "$cid" ]]; then
    return 1
  fi
  status="$(docker inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || true)"
  [[ "$status" == "running" ]] || return 1
  # If a healthcheck is configured, require Health.Status == healthy. Without
  # one (e.g. sandbox / autoheal), running is the strongest signal we have.
  health="$(docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$cid" 2>/dev/null || true)"
  case "$health" in
    healthy|none) return 0 ;;
    *)            return 1 ;;
  esac
}

wait_for_service() {
  local mode="$1" service="$2"
  local attempts=60
  local i
  for ((i = 0; i < attempts; i++)); do
    if service_running "$mode" "$service"; then
      return 0
    fi
    sleep 1
  done
  printf 'bin/agent-sandbox: service `%s` failed to reach running+healthy state\n' "$service" >&2
  return 1
}

start_mode() {
  local mode="$1" want_self="${2:-0}"
  check_runtime_perms
  # Toggle the self sentinel BEFORE compose runs, so compose_cmd picks up the
  # overlay (if requested) on this invocation.
  if [[ "$want_self" == "1" ]]; then
    : > "$SELF_FILE"
  else
    rm -f "$SELF_FILE"
  fi
  local prereqs=(proxy)
  if [[ "$mode" == "default" ]]; then
    prereqs+=(mcp-gateway autoheal)
  fi
  compose_cmd "$mode" up -d "${prereqs[@]}"
  for svc in "${prereqs[@]}"; do
    wait_for_service "$mode" "$svc"
  done
  compose_cmd "$mode" up -d --no-deps sandbox
  printf '%s\n' "$mode" > "$MODE_FILE"
}

ensure_sandbox_running() {
  local mode="$1"
  if service_running "$mode" sandbox; then
    return
  fi
  # Preserve current self state when respawning via shell/passthrough.
  local want_self=0
  [[ -f "$SELF_FILE" ]] && want_self=1
  start_mode "$mode" "$want_self"
}

# Read a `KEY=value` line from $ROOT/.env, falling back to a default. Already-
# exported environment wins, matching docker compose's precedence so the
# script's view of the workspace mount agrees with what compose will mount.
load_env_default() {
  local key=$1 default=$2 val
  if [[ -n "${!key:-}" ]]; then
    printf '%s\n' "${!key}"
    return
  fi
  if [[ -f "$ROOT/.env" ]]; then
    val=$(grep -E "^${key}=" "$ROOT/.env" | tail -n1 | sed -E "s/^${key}=//")
    val=${val%$'\r'}
    val=${val%\"}; val=${val#\"}
    val=${val%\'}; val=${val#\'}
    if [[ -n "$val" ]]; then
      printf '%s\n' "$val"
      return
    fi
  fi
  printf '%s\n' "$default"
}

# POSIX-sh-safe single-quoting so cwd / args with spaces or quotes survive
# the trip through `sh -c` inside the container.
quote_for_sh() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

run_in_sandbox() {
  local mode workspace_dir workspace_target self_dir cwd rel container_dir
  mode="$(resolve_mode "")"

  workspace_dir="$(load_env_default AGENT_SANDBOX_WORKSPACE_DIR "./runtime/workspaces")"
  workspace_target="$(load_env_default AGENT_SANDBOX_WORKSPACE_TARGET "/workspace")"
  case "$workspace_dir" in
    /*) ;;
    *) workspace_dir="$ROOT/$workspace_dir" ;;
  esac
  if ! workspace_dir="$(cd "$workspace_dir" 2>/dev/null && pwd -P)"; then
    printf 'agent-sandbox: workspace dir not found (AGENT_SANDBOX_WORKSPACE_DIR)\n' >&2
    exit 1
  fi

  # The /self mount only exists when the sandbox was brought up with --self;
  # only then does cwd-under-self_dir map to /self/<rel>.
  self_dir=""
  if [[ -f "$SELF_FILE" ]]; then
    self_dir="$(load_env_default AGENT_SANDBOX_SELF_DIR "")"
    if [[ -n "$self_dir" ]]; then
      case "$self_dir" in
        /*) ;;
        *) self_dir="$ROOT/$self_dir" ;;
      esac
      self_dir="$(cd "$self_dir" 2>/dev/null && pwd -P)" || self_dir=""
    fi
  fi

  cwd="$(pwd -P)"
  case "$cwd/" in
    "$workspace_dir"/*)
      rel=${cwd#"$workspace_dir"}
      rel=${rel#/}
      container_dir="$workspace_target"
      [[ -n "$rel" ]] && container_dir="$workspace_target/$rel"
      ;;
    *)
      if [[ -n "$self_dir" ]] && [[ "$cwd/" == "$self_dir"/* ]]; then
        rel=${cwd#"$self_dir"}
        rel=${rel#/}
        container_dir="/self"
        [[ -n "$rel" ]] && container_dir="/self/$rel"
      else
        # cwd is outside both mounts — fall back to /workspace rather than
        # refusing. Print to stderr so the user notices the redirect.
        local hint=" (workspace=$workspace_dir"
        [[ -n "$self_dir" ]] && hint="$hint, self=$self_dir"
        hint="$hint)"
        printf 'agent-sandbox: cwd (%s) is outside known mounts%s; using %s\n' \
          "$cwd" "$hint" "$workspace_target" >&2
        container_dir="$workspace_target"
      fi
      ;;
  esac

  ensure_sandbox_running "$mode"

  local cmd a
  cmd="cd $(quote_for_sh "$container_dir") && exec"
  for a in "$@"; do
    cmd="$cmd $(quote_for_sh "$a")"
  done
  compose_cmd "$mode" exec sandbox sh -c "$cmd"
}

case "${1:-}" in
  up)
    shift
    mode_arg=""
    want_self=0
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --self) want_self=1 ;;
        *)      mode_arg="$1" ;;
      esac
      shift
    done
    mode="$(resolve_mode "$mode_arg")"
    start_mode "$mode" "$want_self"
    ;;
  down)
    mode="$(resolve_mode "${2:-}")"
    compose_cmd "$mode" down
    rm -f "$MODE_FILE" "$SELF_FILE"
    ;;
  shell)
    mode="$(resolve_mode "${2:-}")"
    ensure_sandbox_running "$mode"
    compose_cmd "$mode" exec sandbox zsh -i
    ;;
  logs)
    mode="$(resolve_mode "${2:-}")"
    compose_cmd "$mode" logs --tail=50
    ;;
  doctor) doctor ;;
  '') usage; exit 1 ;;
  -h|--help) usage; exit 0 ;;
  *) run_in_sandbox "$@" ;;
esac
