#!/bin/sh
set -eu

FORCE=0
if [ "${1:-}" = "--force" ]; then
    FORCE=1
fi

TOOL_BIN="${AGENT_SANDBOX_TOOL_BIN:-/tool-bin}"
DEST_DIR="$TOOL_BIN/managed"
DEST="$DEST_DIR/claude"
SUM="$DEST.sha256"
VERSION_FILE="$DEST.version"

if [ "$FORCE" -ne 1 ] && [ -x "$DEST" ]; then
    exit 0
fi

arch="$(dpkg --print-architecture 2>/dev/null || uname -m)"
case "$arch" in
    amd64|x86_64)
        plat="linux-x64"
        ;;
    arm64|aarch64)
        plat="linux-arm64"
        ;;
    *)
        printf 'install-claude: unsupported architecture `%s`\n' "$arch" >&2
        exit 1
        ;;
esac

base="https://downloads.claude.ai/claude-code-releases"
version="${CLAUDE_RELEASE_TAG:-}"
if [ -z "$version" ]; then
    version="$(curl -fsSL "$base/latest")"
fi

mkdir -p "$DEST_DIR"

manifest="$(mktemp)"
tmp="$(mktemp "$DEST_DIR/.claude.XXXXXX")"
cleanup() {
    rm -f "$manifest" "$tmp"
}
trap cleanup EXIT INT TERM

curl -fsSL "$base/$version/manifest.json" -o "$manifest"
expected="$(jq -r --arg plat "$plat" '.platforms[$plat].checksum // empty' "$manifest")"
if [ -z "$expected" ]; then
    printf 'install-claude: checksum for platform `%s` not found in manifest `%s`\n' "$plat" "$version" >&2
    exit 1
fi

curl -fsSL "$base/$version/$plat/claude" -o "$tmp"
printf '%s  %s\n' "$expected" "$tmp" | sha256sum -c - >/dev/null
chmod 0755 "$tmp"
mv "$tmp" "$DEST"
printf '%s  %s\n' "$expected" "$DEST" > "$SUM"
printf '%s\n' "$version" > "$VERSION_FILE"
