#!/bin/sh
# Git credential helper that authenticates GitHub HTTPS using $GITHUB_TOKEN.
#
# Wired into /etc/gitconfig for the https://github.com URL prefix. Only the
# "get" action emits credentials; "store" and "erase" are intentional no-ops
# so git never tries to write a token back to disk.
#
# If $GITHUB_TOKEN is unset or empty, this helper prints nothing and git falls
# back to its remaining helpers (typically failing the operation, which is the
# right behavior — surfaces the missing credential clearly).

case "${1:-}" in
    get) ;;
    *) exit 0 ;;
esac

[ -n "${GITHUB_TOKEN:-}" ] || exit 0

printf 'username=x-access-token\npassword=%s\n' "$GITHUB_TOKEN"
