#!/bin/sh
# Sandbox container init.
#
# /home/node is a host-bind mount: anything the agent writes there persists
# across restarts and is visible on the host side at runtime/home/. Keep the
# default home tree literal and easy to inspect. Common cache APIs point at
# /cache; symlink-based diversion is only for user opt-ins in
# /state/home-ephemeral.local.
#
# Shell startup files (.zshrc / .zshenv / .profile / .bashrc) are unconditionally
# regenerated from the image so persisted home content cannot silently become
# startup code.

set -e

STATE_DIR="${AGENT_SANDBOX_STATE_DIR:-/state}"
TOOL_BIN="${AGENT_SANDBOX_TOOL_BIN:-/tool-bin}"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/xdg-runtime}"
EPHEMERAL_DEFAULT="/etc/agent-sandbox/home-ephemeral.list"
EPHEMERAL_USER="$STATE_DIR/home-ephemeral.local"

mkdir -p \
    "$STATE_DIR/shell" \
    "$STATE_DIR/shell/history" \
    "$STATE_DIR/dev-cache" \
    "$STATE_DIR/xdg/data" \
    "$STATE_DIR/xdg/state" \
    "/cache/xdg" \
    "/cache/npm" \
    "/cache/pnpm-store" \
    "/cache/claude" \
    "$TOOL_BIN/managed" \
    "$TOOL_BIN/user/bin" \
    "$TOOL_BIN/user/npm-global/bin" \
    "$RUNTIME_DIR" \
    "$HOME" \
    "/logs"

chmod 700 "$RUNTIME_DIR" 2>/dev/null || true

# ---------------------------------------------------------------------------
# One-shot cleanup from older layouts. Keep active runtime paths clean: home is
# the canonical state location now, so old /state/<tool> trees are discarded
# instead of being auto-linked or copied back.
# ---------------------------------------------------------------------------

remove_legacy_home_link() {
    rel="$1"; target="$2"
    link="$HOME/$rel"
    [ -L "$link" ] || return 0

    # Some legacy symlink paths are now covered by compose tmpfs mounts. Once a
    # path is a mountpoint, removing it from inside the container fails with
    # EBUSY; host-side cleanup handles any stale symlink before recreate.
    if awk -v p="$link" '$5 == p { found=1 } END { exit found ? 0 : 1 }' /proc/self/mountinfo; then
        return 0
    fi

    actual=$(readlink "$link")
    [ "$actual" = "$target" ] || return 0
    rm -f "$link"
}

remove_legacy_path() {
    src="$1"
    [ -e "$src" ] || [ -L "$src" ] || return 0

    if rm -rf "$src"; then
        echo "sandbox-entrypoint: removed legacy state $src" >&2
    else
        echo "sandbox-entrypoint: WARN failed to remove legacy state $src" >&2
    fi
}

# Tool-bin one-shot from a much earlier layout (kept from the previous entrypoint).
for f in claude claude.sha256 claude.version; do
    if [ -e "$TOOL_BIN/$f" ] && [ ! -e "$TOOL_BIN/managed/$f" ]; then
        mv "$TOOL_BIN/$f" "$TOOL_BIN/managed/$f"
    fi
done

# Old /state-backed home compat symlinks. Drop them so the active home tree is
# real files/dirs again; retired state paths are removed below.
remove_legacy_home_link ".claude" "$STATE_DIR/claude"
remove_legacy_home_link ".claude.json" "$STATE_DIR/claude.json"
remove_legacy_home_link ".codex" "$STATE_DIR/codex"
remove_legacy_home_link ".memsearch" "$STATE_DIR/memsearch"
remove_legacy_home_link ".config" "$STATE_DIR/xdg/config"
remove_legacy_home_link ".local/share" "$STATE_DIR/xdg/data"
remove_legacy_home_link ".local/state" "$STATE_DIR/xdg/state"
remove_legacy_home_link ".ssh" "$STATE_DIR/ssh"
remove_legacy_home_link ".gitconfig" "$STATE_DIR/git/gitconfig"
remove_legacy_home_link ".gitignore_global" "$STATE_DIR/git/gitignore_global"
remove_legacy_home_link ".zsh_history" "$STATE_DIR/shell/zsh_history"
remove_legacy_home_link ".bash_history" "$STATE_DIR/shell/bash_history"

remove_legacy_path "$STATE_DIR/entrypoints"
remove_legacy_path "$STATE_DIR/claude"
remove_legacy_path "$STATE_DIR/claude.json"
remove_legacy_path "$STATE_DIR/codex"
remove_legacy_path "$STATE_DIR/memsearch"
remove_legacy_path "$STATE_DIR/git"
remove_legacy_path "$STATE_DIR/ssh"
remove_legacy_path "$STATE_DIR/shell/zsh_history"
remove_legacy_path "$STATE_DIR/shell/bash_history"
remove_legacy_path "$STATE_DIR/legacy-archive"

chmod 700 "$HOME/.ssh" 2>/dev/null || true

# ---------------------------------------------------------------------------
# Retire default symlinks from the previous layout. Only links that still point
# to the old default targets are removed; user-created links to other targets
# are left alone.
# ---------------------------------------------------------------------------

remove_legacy_home_link ".cache" "/cache/xdg"
remove_legacy_home_link ".npm" "/cache/npm"
remove_legacy_home_link ".pnpm-store" "/cache/pnpm-store"
remove_legacy_home_link ".local/share/Trash" "/tmp/trash"
remove_legacy_home_link ".claude/cache" "/cache/claude"
remove_legacy_home_link ".claude/cache" "/cache/claude/cache"
remove_legacy_home_link ".claude/downloads" "/cache/claude/downloads"
remove_legacy_home_link ".codex/cache" "/cache/codex/cache"
remove_legacy_home_link ".codex/.tmp" "/cache/codex/dot-tmp"
remove_legacy_home_link ".codex/tmp" "/cache/codex/tmp"
remove_legacy_home_link ".codex/shell_snapshots" "/cache/codex/shell-snapshots"
remove_legacy_home_link ".vscode-server" "$STATE_DIR/dev-cache/vscode-server"
remove_legacy_home_link ".cursor-server" "$STATE_DIR/dev-cache/cursor-server"
remove_legacy_home_link ".windsurf-server" "$STATE_DIR/dev-cache/windsurf-server"
remove_legacy_home_link ".nix-portable" "$STATE_DIR/dev-cache/nix-portable"

# ---------------------------------------------------------------------------
# Ephemeral subpaths: compose mounts known cache/temp paths as tmpfs, and users
# may add more via /state/home-ephemeral.local.
# ---------------------------------------------------------------------------

apply_ephemeral() {
    rel="$1"; target="$2"

    # Reject empty fields.
    if [ -z "$rel" ] || [ -z "$target" ]; then
        echo "sandbox-entrypoint: rejecting empty ephemeral entry" >&2
        return
    fi
    # Reject relative paths that try to escape, or absolute home_rel.
    case "$rel" in
        /*|*..*)
            echo "sandbox-entrypoint: rejecting unsafe ephemeral path: $rel" >&2
            return
            ;;
    esac
    # Reject startup chain / PATH-sensitive paths.
    case "$rel" in
        .zshrc|.zshenv|.profile|.bashrc|.bash_profile|.local/bin|.local/bin/*)
            echo "sandbox-entrypoint: rejecting reserved ephemeral path: $rel" >&2
            return
            ;;
    esac
    # Target must be absolute.
    case "$target" in
        /*) ;;
        *)
            echo "sandbox-entrypoint: rejecting relative ephemeral target: $target" >&2
            return
            ;;
    esac

    link="$HOME/$rel"
    # Make the target exist (for dirs). If target is a file path, the parent.
    case "$target" in
        */) mkdir -p "$target" ;;
        *)  mkdir -p "$target" ;;  # treat as dir; callers use dirs only here
    esac

    if [ -L "$link" ]; then
        actual=$(readlink "$link")
        [ "$actual" = "$target" ] && return 0
        rm -f "$link"
    elif [ -e "$link" ]; then
        # Existing real file/dir: move its contents into target if any, then drop.
        if [ -d "$link" ] && [ -n "$(ls -A "$link" 2>/dev/null)" ]; then
            cp -a "$link/." "$target/" 2>/dev/null \
                || echo "sandbox-entrypoint: WARN partial move $link -> $target" >&2
        elif [ -f "$link" ]; then
            cp -p "$link" "$target/" 2>/dev/null || true
        fi
        rm -rf "$link"
    fi

    mkdir -p "$(dirname "$link")"
    ln -s "$target" "$link"
}

apply_ephemeral_list() {
    file="$1"
    [ -r "$file" ] || return 0
    __cr=$(printf '\r')
    __tab=$(printf '\t')
    while IFS= read -r line || [ -n "$line" ]; do
        # Tolerate CRLF.
        line=${line%"$__cr"}
        # Strip leading spaces / tabs.
        while :; do
            case "$line" in
                ' '*|"$__tab"*) line=${line#?} ;;
                *) break ;;
            esac
        done
        # Skip blanks/comments.
        case "$line" in
            ''|\#*) continue ;;
        esac
        # Split first whitespace token as rel, keep the rest (joined with a
        # single space) as target — supports targets that contain spaces.
        # Default IFS already covers space/tab/newline; intentional word-split.
        # shellcheck disable=SC2086
        set -- $line
        rel=${1:-}
        [ "$#" -gt 0 ] && shift
        target=$*
        apply_ephemeral "$rel" "$target"
    done < "$file"
    unset __cr __tab
}

apply_ephemeral_list "$EPHEMERAL_DEFAULT"
apply_ephemeral_list "$EPHEMERAL_USER"

# ---------------------------------------------------------------------------
# /state/env.local seed.
# ---------------------------------------------------------------------------

if [ ! -e "$STATE_DIR/env.local" ]; then
    cat > "$STATE_DIR/env.local" <<'EOF'
# Persistent env vars for sandbox shell sessions.
# Format: one KEY=value per line. Blank lines and lines starting with # are ignored.
# Values are NOT shell-expanded — `$FOO` and `$(cmd)` are stored literally.
# Keys protecting the execution chain are rejected by the loader:
#   PATH, HOME, SHELL, USER, UID, LOGNAME, PWD, OLDPWD
# Loaded by ~/.zshenv, ~/.profile, ~/.bashrc via /etc/agent-sandbox/env-loader.sh.
EOF
fi

# ---------------------------------------------------------------------------
# Shell startup scaffolding: regenerated from the image every start so that
# nothing the agent writes into $HOME/.zshrc etc. survives a restart.
# ---------------------------------------------------------------------------

cp /etc/agent-sandbox/zshrc "$HOME/.zshrc"

cat > "$HOME/.zshenv" <<'EOF'
export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/tmp/xdg-runtime}
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-/cache/xdg}
export XDG_DATA_HOME=${XDG_DATA_HOME:-/state/xdg/data}
export XDG_STATE_HOME=${XDG_STATE_HOME:-/state/xdg/state}
export NPM_CONFIG_CACHE=${NPM_CONFIG_CACHE:-/cache/npm}
# Re-assert tool-bin paths after /etc/profile may have reset PATH on
# login shells (Debian /etc/profile hardcodes a default PATH for non-root).
for p in /usr/local/share/npm-global/bin /tool-bin/user/npm-global/bin /tool-bin/user/bin; do
    case ":$PATH:" in *":$p:"*) ;; *) PATH="$p:$PATH" ;; esac
done
export PATH
[ -r /etc/agent-sandbox/env-loader.sh ] && . /etc/agent-sandbox/env-loader.sh
[ -f /state/shell/zshenv.local ] && . /state/shell/zshenv.local
EOF

cat > "$HOME/.profile" <<'EOF'
export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/tmp/xdg-runtime}
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-/cache/xdg}
export XDG_DATA_HOME=${XDG_DATA_HOME:-/state/xdg/data}
export XDG_STATE_HOME=${XDG_STATE_HOME:-/state/xdg/state}
export NPM_CONFIG_CACHE=${NPM_CONFIG_CACHE:-/cache/npm}
for p in /usr/local/share/npm-global/bin /tool-bin/user/npm-global/bin /tool-bin/user/bin; do
    case ":$PATH:" in *":$p:"*) ;; *) PATH="$p:$PATH" ;; esac
done
export PATH
[ -r /etc/agent-sandbox/env-loader.sh ] && . /etc/agent-sandbox/env-loader.sh
[ -f /state/shell/profile.local ] && . /state/shell/profile.local
EOF

cat > "$HOME/.bashrc" <<'EOF'
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-/cache/xdg}
export XDG_DATA_HOME=${XDG_DATA_HOME:-/state/xdg/data}
export XDG_STATE_HOME=${XDG_STATE_HOME:-/state/xdg/state}
export NPM_CONFIG_CACHE=${NPM_CONFIG_CACHE:-/cache/npm}
HISTFILE=/state/shell/history/bash_history
[ -r /etc/agent-sandbox/env-loader.sh ] && . /etc/agent-sandbox/env-loader.sh
[ -f /state/shell/bashrc.local ] && . /state/shell/bashrc.local
EOF

exec "$@"
