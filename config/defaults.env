PROJECT_NAME=agent-sandbox
RUNTIME_DIR=runtime
DEFAULT_PROFILE=hybrid
SANDBOX_IMAGE=agent-sandbox:dev
PROXY_IMAGE=agent-sandbox-proxy:dev
MCP_GATEWAY_IMAGE=agent-sandbox-mcp-gateway:dev
COMPOSE_PROJECT_NAME=agent_sandbox
COMPOSE_ROOT=deploy/compose
PROXY_RULESET=default
MCP_GATEWAY_PORT=8080
MCP_GITHUB_PATH=/servers/github/mcp
GITHUB_READ_ONLY=1
GITHUB_TOOLSETS=default
GITHUB_DYNAMIC_TOOLSETS=0
