# Copy to .env and adjust for local use. Docker compose reads .env
# automatically from this directory.

# Host paths mounted into the sandbox service.
AGENT_SANDBOX_WORKSPACE_DIR=./runtime/workspaces
AGENT_SANDBOX_STATE_DIR=./runtime/state
AGENT_SANDBOX_LOGS_DIR=./runtime/logs
AGENT_SANDBOX_TOOL_BIN_DIR=./runtime/tool-bin
# Container home is now a host-bind mount so anything dropped under ~/.X
# (e.g. ~/.opencode, ~/.aider.conf) persists across restarts. Caches and
# IDE-server payloads are still routed away from this tree via the
# home-ephemeral list (see docs/persistence.md).
AGENT_SANDBOX_HOME_DIR=./runtime/home

# Container path for the workspace mount.
AGENT_SANDBOX_WORKSPACE_TARGET=/workspace

# Set to ro for read-only workspace mounts.
AGENT_SANDBOX_WORKSPACE_MODE=rw

# Sandbox resource limits.
SANDBOX_PIDS_LIMIT=512
SANDBOX_MEMORY_LIMIT=8g
SANDBOX_CPUS=4

# Trusted sessions only. Leave disabled for unknown repos or agent-driven shell.
ENABLE_PASSWORDLESS_SUDO=0
AGENT_SANDBOX_NO_NEW_PRIVILEGES=true

# Keep the container root filesystem read-only. Turning this off is mainly for
# trusted debugging sessions that need package-manager writes inside the image.
AGENT_SANDBOX_READ_ONLY_ROOT=true

# tmpfs sizing for runtime scratch space (cache/tmp/run).
AGENT_SANDBOX_CACHE_SIZE=1g
AGENT_SANDBOX_TMP_SIZE=512m
AGENT_SANDBOX_RUN_SIZE=64m

# Host ports published from the proxy container (sandbox shares its netns,
# so all sandbox-side listeners surface here). Format follows docker compose
# `ports:` syntax: "[HOST_IP:]HOST_PORT[:CONTAINER_PORT]" or a range.
# Default binds 7000-7010 to host loopback only. Examples:
#   AGENT_SANDBOX_PUBLISH_PORTS=127.0.0.1:8080:8080            # single port
#   AGENT_SANDBOX_PUBLISH_PORTS=127.0.0.1:7000-7020:7000-7020  # wider range
#   AGENT_SANDBOX_PUBLISH_PORTS=0.0.0.0:7000-7010:7000-7010    # LAN-visible
# Adding/removing/changing this requires recreating the proxy container
# (e.g. `bin/agent-sandbox down && bin/agent-sandbox up`); Docker has no
# live port-add API.
AGENT_SANDBOX_PUBLISH_PORTS=127.0.0.1:7000-7010:7000-7010
